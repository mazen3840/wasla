#!/usr/bin/env sh
if [ -z "$JAVA_HOME" ] ; then
  if [ -n "$(command -v java)" ] ; then
    JAVA_BIN_PATH=$(command -v java)
    JAVA_HOME=$(dirname $(dirname "$JAVA_BIN_PATH"))
  fi
fi

if [ -z "$JAVA_HOME" ] ; then
  echo "WARNING: JAVA_HOME is not set and no 'java' command could be found in your PATH."
  echo "You may not be able to run Gradle without a JDK."
fi

APP_NAME="Gradle Wrapper"
APP_BASE_NAME="gradle"

CLI_OPTIONS="$@"

# Determine the wrapper jar location.
PRG="$0"
while [ -h "$PRG" ] ; do
  ls=$(ls -ld "$PRG")
  link=$(expr "$ls" : '.*-> \(.*\)$')
  if expr "$link" : '/.*' > /dev/null; then
    PRG="$link"
  else
    PRG=$(dirname "$PRG")/"$link"
  fi
  unset ls
  unset link
done

PRGDIR=$(dirname "$PRG")

JAR_PATH="$PRGDIR/gradle/wrapper/gradle-wrapper.jar"

if [ ! -f "$JAR_PATH" ] ; then
  echo "Error: Could not find gradle wrapper jar at $JAR_PATH"
  exit 1
fi

exec "$JAVA_HOME/bin/java" -jar "$JAR_PATH" $CLI_OPTIONS
